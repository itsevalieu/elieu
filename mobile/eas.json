{
  "cli": {
    "version": ">= 10.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "env": {
        "API_BASE": "http://localhost:8081"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "API_BASE": "https://api.evalieu.com"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "API_BASE": "https://api.evalieu.com"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "APPLE_ID",
        "ascAppId": "ASC_APP_ID",
        "appleTeamId": "APPLE_TEAM_ID"
      },
      "android": {
        "serviceAccountKeyPath": "./google-service-account.json",
        "track": "internal"
      }
    }
  }
}
